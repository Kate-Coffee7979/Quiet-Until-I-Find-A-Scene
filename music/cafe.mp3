<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Café Site</title>
</head>

<body style="margin:0; font-family:sans-serif; background:#f5f1e8;">

  <div style="height:100vh; display:flex; justify-content:center; align-items:center; flex-direction:column;">
    <h1>Quiet Café Moment</h1>
    <p>Tap anywhere to start music</p>
  </div>

  <!-- 🎵 음악 -->
  <audio id="bgm" loop>
    <source src="music/cafe.mp3" type="audio/mpeg">
  </audio>

  <!-- ✔ 클릭하면 음악 시작 -->
  <script>
    document.body.addEventListener('click', function () {
      const audio = document.getElementById('bgm');
      audio.play();
    }, { once: true });
  </script>

</body>
</html>
