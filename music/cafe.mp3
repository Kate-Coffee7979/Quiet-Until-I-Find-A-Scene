<div id="start" style="height:100vh; display:flex; justify-content:center; align-items:center;">
  Tap anywhere to enter café
</div>

<audio id="bgm" loop>
  <source src="music/cafe.mp3" type="audio/mpeg">
</audio>

<script>
document.getElementById('start').addEventListener('click', function () {
  document.getElementById('bgm').play();
  this.style.display = 'none';
});
</script>
